+        UIView<NVNavigationBar> *navigationBar = [self findNavigationBar];
+        if (!navigationBar || !navigationBar.largeTitle || navigationBar.isHidden)
+            return;
+        UIScrollView *scrollView = [self findLargeTitleContentScrollView:self.view depth:0];
+        if (scrollView && scrollView != _nvBoundContentScrollView) {
+            [self setContentScrollView:scrollView forEdge:NSDirectionalRectEdgeTop];
+            _nvBoundContentScrollView = scrollView;
+        }
+    }
+}
