+- (UIScrollView *)findLargeTitleContentScrollView:(UIView *)view depth:(NSInteger)depth
+{
+    if (depth > 14)
+        return nil;
+    if ([view isKindOfClass:[UIScrollView class]]) {
+        UIScrollView *scrollView = (UIScrollView *)view;
+        // Only bind the scene's main vertical surface: skip horizontal
+        // carousels/chip rows and small embedded scrollers.
+        BOOL tallEnough = scrollView.frame.size.height >= self.view.bounds.size.height * 0.4;
+        BOOL wideEnough = scrollView.frame.size.width >= self.view.bounds.size.width * 0.8;
+        if (tallEnough && wideEnough)
+            return scrollView;
+    }
+    for (UIView *subview in view.subviews) {
+        UIScrollView *found = [self findLargeTitleContentScrollView:subview depth:depth + 1];
+        if (found)
+            return found;
+    }
+    return nil;
 }
 
